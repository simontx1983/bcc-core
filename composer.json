{
  "name": "bcc/core",
  "description": "BCC Core Plugin",
  "type": "wordpress-plugin",
  "autoload": {
    "psr-4": {
      "BCC\\Core\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "szepeviktor/phpstan-wordpress": "^2.0"
  }
}